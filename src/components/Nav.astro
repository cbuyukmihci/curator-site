---
interface Props {
  locale: string;
}

const { locale } = Astro.props;
const isEn = locale === 'en';

const navLinks = isEn
  ? [
      { label: 'Services', href: '/en/services/' },
      { label: 'About', href: '/en/about/' },
      { label: 'How We Work', href: '/en/how-we-work/' },
      { label: 'Sectors', href: '/en/sectors/' },
      { label: 'Partners', href: '/en/partners/' },
      { label: 'Insights', href: '/en/insights/' },
      { label: 'Contact', href: '/en/contact/' },
    ]
  : [
      { label: 'Hizmetler', href: '/tr/hizmetler/' },
      { label: 'Hakkımızda', href: '/tr/hakkimizda/' },
      { label: 'Nasıl Çalışıyoruz', href: '/tr/nasil-calisiyoruz/' },
      { label: 'Sektörler', href: '/tr/sektorler/' },
      { label: 'Partnerler', href: '/tr/partnerler/' },
      { label: 'Yazılar', href: '/tr/yazilar/' },
      { label: 'İletişim', href: '/tr/iletisim/' },
    ];

const ctaLabel = isEn ? 'Book a Meeting' : 'Toplantı Planla';
const currentPath = Astro.url.pathname;
const altPath = isEn
  ? currentPath.replace(/^\/en/, '/tr')
  : currentPath.replace(/^\/tr/, '/en');
const altLabel = isEn ? 'TR' : 'EN';
---

<nav class="fixed top-0 w-full z-50 glass ambient-shadow">
  <div class="flex justify-between items-center w-full px-6 md:px-8 py-4 max-w-7xl mx-auto">
    <!-- Logo -->
    <a href={isEn ? '/en/' : '/tr/'} class="text-xl font-extrabold tracking-tighter text-primary-container font-headline">
      CURATOR
    </a>

    <!-- Desktop Nav -->
    <div class="hidden lg:flex items-center gap-6">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <a
            href={link.href}
            class={`text-sm font-medium transition-colors ${
              isActive
                ? 'text-primary-container border-b-2 border-primary-container pb-1'
                : 'text-on-surface-variant hover:text-primary-container'
            }`}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <!-- Right Actions -->
    <div class="flex items-center gap-4">
      <!-- Language Switcher -->
      <a
        href={altPath}
        class="text-xs font-bold tracking-widest text-on-surface-variant hover:text-primary-container transition-colors px-2 py-1"
      >
        {altLabel}
      </a>

      <!-- CTA Button -->
      <a
        href={isEn ? '/en/contact/' : '/tr/iletisim/'}
        class="hidden sm:inline-flex signature-gradient text-white px-6 py-2.5 rounded-lg font-semibold text-sm transition-transform active:scale-[0.98] hover:opacity-95"
      >
        {ctaLabel}
      </a>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-1.5 p-2"
        aria-label="Menu"
      >
        <span class="block w-6 h-0.5 bg-primary-container transition-transform" id="bar1"></span>
        <span class="block w-6 h-0.5 bg-primary-container transition-opacity" id="bar2"></span>
        <span class="block w-6 h-0.5 bg-primary-container transition-transform" id="bar3"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-surface-container-lowest border-t border-outline-variant/10">
    <div class="px-6 py-6 space-y-4 max-w-7xl mx-auto">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block text-base font-medium text-on-surface-variant hover:text-primary-container transition-colors py-2"
        >
          {link.label}
        </a>
      ))}
      <a
        href={isEn ? '/en/contact/' : '/tr/iletisim/'}
        class="block signature-gradient text-white text-center px-6 py-3 rounded-lg font-semibold text-sm mt-4"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      bar1?.classList.toggle('rotate-45');
      bar1?.classList.toggle('translate-y-2');
      bar2?.classList.toggle('opacity-0');
      bar3?.classList.toggle('-rotate-45');
      bar3?.classList.toggle('-translate-y-2');
    });
  }
</script>
