---
interface Props {
  locale: string;
  icon: string;
  title: string;
  subtitle: string;
  description: string;
  features: { title: string; description: string }[];
  outcomes: string[];
  ctaLabel: string;
  ctaHref: string;
}

const { locale, icon, title, subtitle, description, features, outcomes, ctaLabel, ctaHref } = Astro.props;
const isEn = locale === 'en';
const outcomesTitle = isEn ? 'Expected Outcomes' : 'Beklenen Sonuçlar';
const featuresTitle = isEn ? 'What We Cover' : 'Kapsam';
---

<main class="pt-20">
  <!-- Hero -->
  <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
      <div class="lg:col-span-7">
        <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">{subtitle}</span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
          {title}
        </h1>
        <p class="text-lg text-secondary leading-relaxed max-w-2xl">
          {description}
        </p>
      </div>
      <div class="lg:col-span-5 flex justify-center">
        <div class="w-32 h-32 signature-gradient rounded-2xl flex items-center justify-center ambient-shadow">
          <span class="material-symbols-outlined text-white text-5xl">{icon}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 px-6 md:px-8 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
      <h2 class="text-3xl font-extrabold text-primary-container mb-16 font-headline">{featuresTitle}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {features.map((feature) => (
          <div class="bg-surface-container-lowest p-8 rounded-xl ghost-border">
            <h4 class="text-lg font-bold text-primary-container mb-3 font-headline">{feature.title}</h4>
            <p class="text-secondary text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="py-24 px-6 md:px-8 bg-surface">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-3xl font-extrabold text-primary-container mb-8 font-headline">{outcomesTitle}</h2>
        <ul class="space-y-4">
          {outcomes.map((outcome) => (
            <li class="flex items-start gap-4">
              <span class="material-symbols-outlined text-on-tertiary-container mt-0.5">check_circle</span>
              <span class="text-secondary leading-relaxed">{outcome}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="flex justify-center">
        <a
          href={ctaHref}
          class="signature-gradient text-white px-12 py-5 rounded-lg font-bold text-lg ambient-shadow hover:opacity-95 transition-all active:scale-[0.98] inline-block"
        >
          {ctaLabel}
        </a>
      </div>
    </div>
  </section>

  <!-- Additional content slot -->
  <slot />
</main>
