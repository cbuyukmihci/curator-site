---
interface Props {
  locale: string;
}

const { locale } = Astro.props;
const isEn = locale === 'en';

const serviceLinks = isEn
  ? [
      { label: 'Growth Strategy', href: '/en/services/strategic-growth/' },
      { label: 'Supplier Development', href: '/en/services/supplier-development/' },
      { label: 'Compliance & Security', href: '/en/services/compliance-security/' },
      { label: 'IT & Cloud Solutions', href: '/en/services/it-cloud-solutions/' },
      { label: 'Financial Advisory', href: '/en/services/financial-advisory/' },
    ]
  : [
      { label: 'Stratejik Büyüme', href: '/tr/hizmetler/stratejik-buyume/' },
      { label: 'Tedarikçi Geliştirme', href: '/tr/hizmetler/tedarikci-gelistirme/' },
      { label: 'Uyumluluk & Güvenlik', href: '/tr/hizmetler/uyumluluk-bilgi-guvenligi/' },
      { label: 'IT & Bulut Çözümleri', href: '/tr/hizmetler/it-bulut-cozumleri/' },
      { label: 'Finansal Danışmanlık', href: '/tr/hizmetler/finansal-danismanlik/' },
    ];

const companyLinks = isEn
  ? [
      { label: 'About', href: '/en/about/' },
      { label: 'How We Work', href: '/en/how-we-work/' },
      { label: 'Partners', href: '/en/partners/' },
      { label: 'Sectors', href: '/en/sectors/' },
      { label: 'Contact Us', href: '/en/contact/' },
    ]
  : [
      { label: 'Hakkımızda', href: '/tr/hakkimizda/' },
      { label: 'Nasıl Çalışıyoruz', href: '/tr/nasil-calisiyoruz/' },
      { label: 'Partnerler', href: '/tr/partnerler/' },
      { label: 'Sektörler', href: '/tr/sektorler/' },
      { label: 'İletişim', href: '/tr/iletisim/' },
    ];

const servicesTitle = isEn ? 'Services' : 'Hizmetler';
const companyTitle = isEn ? 'Company' : 'Şirket';
const contactTitle = isEn ? 'Contact' : 'İletişim';
const tagline = isEn
  ? 'Strategic advisory for industrial growth, compliance readiness, and market transformation.'
  : 'Endüstriyel büyüme, uyumluluk hazırlığı ve pazar dönüşümü için stratejik danışmanlık.';
const copyright = isEn
  ? `© ${new Date().getFullYear()} Curator Advisory. All rights reserved.`
  : `© ${new Date().getFullYear()} Curator Danışmanlık. Tüm hakları saklıdır.`;
---

<footer class="bg-navy text-white border-t border-white/5" style="background: linear-gradient(180deg, #0a0f1e 0%, #080d1a 100%);">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-20 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-4 space-y-6">
        <div class="text-xl font-extrabold tracking-tight font-display">CURATOR</div>
        <p class="text-on-dark-secondary text-sm leading-relaxed max-w-xs">
          {tagline}
        </p>
        <div class="flex gap-4 pt-2">
          <a href="mailto:info@curator.com.tr" class="w-9 h-9 rounded-lg bg-navy-card border border-navy-border flex items-center justify-center hover:border-gold/40 transition-colors">
            <span class="material-symbols-outlined text-on-dark-secondary text-base">mail</span>
          </a>
          <a href="tel:+902121234567" class="w-9 h-9 rounded-lg bg-navy-card border border-navy-border flex items-center justify-center hover:border-gold/40 transition-colors">
            <span class="material-symbols-outlined text-on-dark-secondary text-base">call</span>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="lg:col-span-3 space-y-5">
        <h5 class="text-xs font-bold uppercase tracking-[0.15em] text-on-dark-muted">{servicesTitle}</h5>
        <ul class="space-y-3">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-on-dark-secondary text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="lg:col-span-2 space-y-5">
        <h5 class="text-xs font-bold uppercase tracking-[0.15em] text-on-dark-muted">{companyTitle}</h5>
        <ul class="space-y-3">
          {companyLinks.map((link) => (
            <li>
              <a href={link.href} class="text-on-dark-secondary text-sm hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="lg:col-span-3 space-y-5">
        <h5 class="text-xs font-bold uppercase tracking-[0.15em] text-on-dark-muted">{contactTitle}</h5>
        <div class="space-y-4 text-sm text-on-dark-secondary">
          <div>
            <p class="text-white font-medium mb-1">İstanbul</p>
            <p>Levent, İstanbul</p>
          </div>
          <div>
            <p class="text-white font-medium mb-1">Ankara</p>
            <p>Söğütözü, Ankara</p>
          </div>
          <div class="pt-1">
            <a href="mailto:info@curator.com.tr" class="hover:text-white transition-colors">info@curator.com.tr</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-navy-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-on-dark-muted text-xs">{copyright}</p>
      <div class="flex items-center gap-1 text-on-dark-muted text-xs">
        <span class="w-2 h-2 rounded-full bg-gold/60"></span>
        <span>Istanbul & Ankara</span>
      </div>
    </div>
  </div>
</footer>
