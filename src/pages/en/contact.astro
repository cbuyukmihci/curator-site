---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact | CURATOR" description="Let's discuss your growth and readiness priorities." locale="en">
  <main>
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-16 md:pt-40 md:pb-20 relative z-10">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Contact</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display mb-6">
            Let's Plan Your Next Step.
          </h1>
          <p class="text-on-dark-secondary text-lg leading-relaxed">
            Our advisors operate at the intersection of industrial precision and strategic growth.
          </p>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-8">
          <form action="https://api.web3forms.com/submit" method="POST" class="card-light rounded-2xl p-8 md:p-12 space-y-8">
            <input type="hidden" name="access_key" value="6e88065e-781b-4a82-b2e0-59ff7b377a36" />
            <input type="hidden" name="subject" value="New Meeting Request - Curator Website" />
            <input type="hidden" name="from_name" value="Curator Website" />
            <input type="hidden" name="redirect" value="https://web3forms.com/success" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs uppercase tracking-widest text-muted font-bold" for="name">Full Name</label>
                <input class="w-full bg-slate border border-border px-4 py-3 rounded-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-sm" id="name" name="name" type="text" placeholder="Your Full Name" required />
              </div>
              <div class="space-y-2">
                <label class="text-xs uppercase tracking-widest text-muted font-bold" for="company">Company</label>
                <input class="w-full bg-slate border border-border px-4 py-3 rounded-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-sm" id="company" name="company" type="text" placeholder="Company Name" />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-xs uppercase tracking-widest text-muted font-bold" for="email">Email</label>
                <input class="w-full bg-slate border border-border px-4 py-3 rounded-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-sm" id="email" name="email" type="email" placeholder="example@company.com" required />
              </div>
              <div class="space-y-2">
                <label class="text-xs uppercase tracking-widest text-muted font-bold" for="phone">Phone</label>
                <input class="w-full bg-slate border border-border px-4 py-3 rounded-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-sm" id="phone" name="phone" type="tel" placeholder="+90 (5XX) XXX XX XX" />
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-xs uppercase tracking-widest text-muted font-bold" for="interest">Area of Interest</label>
              <select class="w-full bg-slate border border-border px-4 py-3 rounded-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-sm" id="interest" name="interest">
                <option value="">Select</option>
                <option value="growth">Strategic Growth & Market Development</option>
                <option value="supplier">Supplier Development & Audit</option>
                <option value="compliance">Compliance & Information Security</option>
                <option value="it">IT & Cloud Solutions</option>
                <option value="finance">Financial & Strategic Advisory</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="space-y-2">
              <label class="text-xs uppercase tracking-widest text-muted font-bold" for="message">Your Message</label>
              <textarea class="w-full bg-slate border border-border px-4 py-3 rounded-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 transition-all text-sm" id="message" name="message" rows="5" placeholder="Brief information about your company's current state and goals."></textarea>
            </div>

            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

            <button type="submit" class="btn-gold px-10 py-4 rounded-lg text-base w-full md:w-auto">
              Send Request
            </button>
          </form>
        </div>

        <aside class="lg:col-span-4 space-y-10">
          <div>
            <h3 class="text-xs uppercase tracking-[0.2em] text-gold font-bold mb-6">Regional Offices</h3>
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="w-11 h-11 shrink-0 bg-navy rounded-lg flex items-center justify-center">
                  <span class="material-symbols-outlined text-gold text-base">location_on</span>
                </div>
                <div>
                  <h4 class="font-bold text-heading font-display">Istanbul HQ</h4>
                  <p class="text-sm text-body mt-1">Levent, Istanbul</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-11 h-11 shrink-0 bg-navy rounded-lg flex items-center justify-center">
                  <span class="material-symbols-outlined text-gold text-base">location_on</span>
                </div>
                <div>
                  <h4 class="font-bold text-heading font-display">Ankara Office</h4>
                  <p class="text-sm text-body mt-1">Söğütözü, Ankara</p>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-slate rounded-xl p-6 space-y-5">
            <h3 class="text-xs uppercase tracking-widest text-gold font-bold">Direct Contact</h3>
            <div class="space-y-4">
              <a href="mailto:info@curator.com.tr" class="flex items-center gap-4 group">
                <div class="w-10 h-10 rounded-lg bg-white border border-border flex items-center justify-center group-hover:bg-navy group-hover:border-navy transition-colors">
                  <span class="material-symbols-outlined text-sm text-body group-hover:text-gold transition-colors">mail</span>
                </div>
                <div>
                  <p class="text-xs text-muted uppercase tracking-wider font-semibold">Email</p>
                  <p class="text-sm font-medium text-heading">info@curator.com.tr</p>
                </div>
              </a>
              <a href="tel:+902121234567" class="flex items-center gap-4 group">
                <div class="w-10 h-10 rounded-lg bg-white border border-border flex items-center justify-center group-hover:bg-navy group-hover:border-navy transition-colors">
                  <span class="material-symbols-outlined text-sm text-body group-hover:text-gold transition-colors">call</span>
                </div>
                <div>
                  <p class="text-xs text-muted uppercase tracking-wider font-semibold">Phone</p>
                  <p class="text-sm font-medium text-heading">+90 (212) 123 45 67</p>
                </div>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>
</BaseLayout>
