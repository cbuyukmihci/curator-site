---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  { icon: 'public', title: 'Strategic Growth', desc: 'Market entry strategy, customer segmentation, and growth roadmap development.', href: '/en/services/strategic-growth/' },
  { icon: 'inventory', title: 'Supplier Development', desc: 'Supplier assessment, gap analysis, and audit preparation support.', href: '/en/services/supplier-development/' },
  { icon: 'security', title: 'Compliance & Security', desc: 'KVKK, ISO 27001 readiness, and information security framework setup.', href: '/en/services/compliance-security/' },
  { icon: 'cloud', title: 'IT & Cloud Solutions', desc: 'Infrastructure modernization, cloud migration, and system integration.', href: '/en/services/it-cloud-solutions/' },
  { icon: 'account_balance', title: 'Financial Advisory', desc: 'Company valuation, investment readiness, and strategic planning.', href: '/en/services/financial-advisory/' },
];

const stats = [
  { number: '50+', label: 'Expert Team' },
  { number: '4', label: 'Industry Focus' },
  { number: '5', label: 'Service Areas' },
  { number: '150+', label: 'Projects Delivered' },
];

const steps = [
  { num: '01', title: 'Assess', desc: 'We analyze your current state, goals, and opportunity areas.' },
  { num: '02', title: 'Plan', desc: 'We build a practical roadmap with clear priorities.' },
  { num: '03', title: 'Execute', desc: 'We coordinate delivery through expert teams and partners.' },
  { num: '04', title: 'Improve', desc: 'We provide continuous monitoring and growth support.' },
];
---

<BaseLayout
  title="CURATOR | Growth, Compliance & Strategic Advisory"
  description="We support industrial, defense, and technology-focused companies with market development, supplier readiness, compliance, IT/cloud enablement, and strategic finance solutions."
  locale="en"
>
  <main>
    <!-- ═══ HERO ═══ -->
    <section class="relative bg-hero min-h-[90vh] flex items-center overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-32 md:py-40 relative z-10 w-full">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-8">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">B2B Strategic Advisory</span>
          </div>
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.08] tracking-tight font-display mb-8">
            Grow. Comply.
            <span class="block text-on-dark-secondary">Become Ready for Bigger Opportunities.</span>
          </h1>
          <p class="text-on-dark-secondary text-lg md:text-xl leading-relaxed max-w-2xl mb-12">
            We support industrial, defense, and technology-focused companies with market development, supplier readiness, compliance, and strategic finance solutions.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/en/contact/" class="btn-gold px-8 py-4 rounded-lg text-base text-center">
              Book a Meeting
            </a>
            <a href="/en/services/" class="btn-ghost-light px-8 py-4 rounded-lg text-base text-center">
              View Services
            </a>
          </div>
        </div>
      </div>

      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
      <div class="absolute bottom-20 right-[30%] w-96 h-96 bg-blue-500/5 rounded-full blur-[120px]"></div>
    </section>

    <!-- ═══ STATS BAR ═══ -->
    <section class="bg-navy-light border-t border-navy-border">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 md:py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="stat-number text-4xl md:text-5xl mb-2">{stat.number}</div>
              <div class="text-on-dark-secondary text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ SERVICES ═══ -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Our Services</span>
            </div>
            <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight font-display">
              Integrated Solutions for<br />Sustainable Growth.
            </h2>
          </div>
          <a href="/en/services/" class="text-gold font-semibold text-sm flex items-center gap-2 hover:gap-3 transition-all shrink-0">
            All Services
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((service) => (
            <a href={service.href} class="card-light rounded-xl p-8 group">
              <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-gold text-xl">{service.icon}</span>
              </div>
              <h3 class="text-lg font-bold text-heading mb-3 font-display group-hover:text-gold transition-colors">{service.title}</h3>
              <p class="text-body text-sm leading-relaxed mb-4">{service.desc}</p>
              <span class="text-gold text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                Learn More
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ WHO WE HELP ═══ -->
    <section class="py-24 md:py-32 bg-slate">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Who We Work With</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight font-display mb-8">
              A Strategic Partner for Companies Ready to Grow.
            </h2>
            <div class="space-y-8">
              <div class="flex gap-5">
                <div class="stat-number text-2xl font-extrabold shrink-0 w-8">01</div>
                <div>
                  <h4 class="font-bold text-heading mb-1 font-display">Suppliers</h4>
                  <p class="text-body text-sm leading-relaxed">Enhance credibility through certified compliance and connect with tier-one partners.</p>
                </div>
              </div>
              <div class="flex gap-5">
                <div class="stat-number text-2xl font-extrabold shrink-0 w-8">02</div>
                <div>
                  <h4 class="font-bold text-heading mb-1 font-display">Mid-Sized Companies</h4>
                  <p class="text-body text-sm leading-relaxed">Build stronger systems, compliance infrastructure, and growth structure.</p>
                </div>
              </div>
              <div class="flex gap-5">
                <div class="stat-number text-2xl font-extrabold shrink-0 w-8">03</div>
                <div>
                  <h4 class="font-bold text-heading mb-1 font-display">Business Owners</h4>
                  <p class="text-body text-sm leading-relaxed">Prepare for investment, scale-up, or long-term strategic positioning.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="relative">
            <img
              src="/images/meeting.jpg"
              alt="Curator team meeting"
              class="w-full aspect-[4/3] object-cover rounded-2xl"
              loading="lazy"
            />
            <div class="absolute -bottom-6 -left-6 bg-navy text-white p-6 rounded-xl max-w-[280px] hidden md:block">
              <p class="text-sm leading-relaxed mb-3 text-on-dark-secondary italic">"Curator redefined our compliance roadmap, saving us months of regulatory friction."</p>
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-gold"></div>
                <p class="text-xs font-bold tracking-wider uppercase text-on-dark-muted">CTO, Global Industrial Corp</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ METHODOLOGY ═══ -->
    <section class="py-24 md:py-32 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
        <div class="text-center mb-16">
          <div class="flex items-center justify-center gap-3 mb-4">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Methodology</span>
            <div class="accent-line"></div>
          </div>
          <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight font-display">
            How We Work
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map((step, i) => (
            <div class={`card-dark rounded-xl p-8 relative ${i === 2 ? 'border-t-2 border-t-gold' : ''}`}>
              <span class="text-5xl font-extrabold text-navy-border font-display block mb-6">{step.num}</span>
              <h3 class="text-xl font-bold text-white mb-3 font-display">{step.title}</h3>
              <p class="text-on-dark-secondary text-sm leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="absolute top-1/2 left-[20%] w-64 h-64 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <!-- ═══ VISUAL BREAK ═══ -->
    <section class="bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6">
        <img
          src="/images/factory.jpg"
          alt="Industrial manufacturing"
          class="w-full h-72 md:h-96 object-cover rounded-2xl"
          loading="lazy"
        />
      </div>
    </section>

    <!-- ═══ SECTORS ═══ -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Sectors</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight font-display mb-6">
              Built for Industries Where Readiness Matters.
            </h2>
            <p class="text-body leading-relaxed mb-10">
              Our work is especially relevant in sectors where growth, compliance, supplier capability, and trust are tightly connected.
            </p>
            <a href="/en/sectors/" class="text-gold font-semibold text-sm flex items-center gap-2 hover:gap-3 transition-all">
              All Sectors
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { icon: 'shield', name: 'Defense' },
              { icon: 'directions_car', name: 'Automotive' },
              { icon: 'precision_manufacturing', name: 'Manufacturing' },
              { icon: 'memory', name: 'Technology' },
            ].map((sector) => (
              <div class="card-light rounded-xl p-6 text-center">
                <div class="w-12 h-12 mx-auto rounded-lg bg-slate flex items-center justify-center mb-4">
                  <span class="material-symbols-outlined text-navy text-xl">{sector.icon}</span>
                </div>
                <p class="text-sm font-bold text-heading font-display">{sector.name}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="py-24 md:py-32 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="accent-line"></div>
        </div>
        <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight font-display mb-6">
          Ready to Scale Your Business?
        </h2>
        <p class="text-on-dark-secondary text-lg mb-10 max-w-xl mx-auto">
          Let's discuss your company's growth and readiness priorities together.
        </p>
        <a href="/en/contact/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Contact Our Experts
        </a>
      </div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gold/5 rounded-full blur-[150px]"></div>
    </section>
  </main>
</BaseLayout>
