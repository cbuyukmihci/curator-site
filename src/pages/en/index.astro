---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CURATOR | Growth, Compliance & Strategic Enablement"
  description="We support industrial, defense, and technology-focused companies with market development, supplier readiness, compliance, IT/cloud enablement, and strategic finance solutions."
  locale="en"
>
  <main class="pt-20">
    <!-- Hero Section -->
    <section class="relative px-6 md:px-8 py-20 md:py-32 bg-surface overflow-hidden">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="z-10">
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
            Grow, Comply, and Become <br />
            <span class="text-on-primary-container">Ready for Bigger Opportunities.</span>
          </h1>
          <p class="text-lg md:text-xl text-on-surface-variant max-w-xl mb-10 leading-relaxed">
            We support industrial, defense, and technology-focused companies with market development,
            supplier readiness, compliance, IT/cloud enablement, and strategic finance solutions.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/en/contact/"
              class="signature-gradient text-white px-10 py-4 rounded-lg font-bold text-lg ambient-shadow hover:opacity-95 transition-all active:scale-[0.98] text-center"
            >
              Book a Meeting
            </a>
            <a
              href="/en/services/"
              class="text-primary-container ghost-border px-10 py-4 rounded-lg font-bold text-lg hover:bg-surface-container-low transition-all text-center"
            >
              View Services
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <img src="/images/hero-growth.svg" alt="Growth analytics" class="w-full rounded-xl" loading="eager" />
        </div>
      </div>

      <!-- Technical Data Markers -->
      <div class="absolute top-1/4 left-10 opacity-10 hidden xl:block">
        <div class="text-[10px] font-mono tracking-widest uppercase mb-2">System.Compliance_Status</div>
        <div class="w-32 h-[1px] bg-primary-container"></div>
      </div>
    </section>

    <!-- Value Proposition Pillars -->
    <section class="bg-surface-container-low py-20 md:py-24 px-6 md:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-16">
          <div class="space-y-6">
            <div class="w-12 h-12 flex items-center justify-center bg-primary-container rounded-lg">
              <span class="material-symbols-outlined text-white">trending_up</span>
            </div>
            <h3 class="text-2xl font-bold text-primary-container font-headline">Growth Strategy</h3>
            <p class="text-secondary leading-relaxed">
              Growth strategy that turns ambition into a practical market roadmap.
            </p>
          </div>
          <div class="space-y-6">
            <div class="w-12 h-12 flex items-center justify-center bg-primary-container rounded-lg">
              <span class="material-symbols-outlined text-white">verified_user</span>
            </div>
            <h3 class="text-2xl font-bold text-primary-container font-headline">Compliance & Audit</h3>
            <p class="text-secondary leading-relaxed">
              Compliance and audit readiness that reduce friction with larger customers and stricter ecosystems.
            </p>
          </div>
          <div class="space-y-6">
            <div class="w-12 h-12 flex items-center justify-center bg-primary-container rounded-lg">
              <span class="material-symbols-outlined text-white">hub</span>
            </div>
            <h3 class="text-2xl font-bold text-primary-container font-headline">Integrated Execution</h3>
            <p class="text-secondary leading-relaxed">
              Integrated execution through trusted partners instead of fragmented vendor management.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section (Bento Grid) -->
    <section class="py-20 md:py-24 px-6 md:px-8 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="mb-14">
          <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">Core Competencies</span>
          <h2 class="text-4xl md:text-5xl font-extrabold text-primary-container font-headline">What We Do</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-6 gap-6">
          <div class="md:col-span-3 bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all">
            <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">public</span>
            <h4 class="text-xl font-bold mb-4 font-headline">Strategic Growth & Market Development</h4>
            <p class="text-secondary text-sm leading-relaxed">
              We support companies that want to enter new sectors, reach new customer groups, or build a more focused growth strategy.
            </p>
          </div>
          <div class="md:col-span-3 bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all">
            <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">inventory</span>
            <h4 class="text-xl font-bold mb-4 font-headline">Supplier Development & Audit</h4>
            <p class="text-secondary text-sm leading-relaxed">
              We help suppliers understand where they stand, close critical gaps, and prepare for stricter customer expectations and audit processes.
            </p>
          </div>
          <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all">
            <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">security</span>
            <h4 class="text-xl font-bold mb-4 font-headline">Compliance & Information Security</h4>
            <p class="text-secondary text-sm leading-relaxed">
              KVKK, ISO 27001 readiness and implementation support.
            </p>
          </div>
          <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all">
            <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">cloud</span>
            <h4 class="text-xl font-bold mb-4 font-headline">IT & Cloud Solutions</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Infrastructure modernization and cloud transition for scale and resilience.
            </p>
          </div>
          <div class="md:col-span-2 bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all">
            <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">account_balance</span>
            <h4 class="text-xl font-bold mb-4 font-headline">Financial & Strategic Advisory</h4>
            <p class="text-secondary text-sm leading-relaxed">
              Valuation, strategic planning, and investment readiness support.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Who We Help Section -->
    <section class="py-20 md:py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
          <div>
            <h2 class="text-4xl md:text-5xl font-extrabold text-primary-container mb-8 font-headline">Who We Work With</h2>
            <p class="text-lg text-secondary mb-12">
              Whether you are a global supplier or a scaling enterprise, our platform provides the tools to navigate compliance and unlock new growth avenues.
            </p>
            <div class="space-y-8">
              <div class="flex gap-6">
                <span class="text-primary-container font-black text-2xl font-headline">01</span>
                <div>
                  <h4 class="font-bold text-lg text-primary-container mb-2 font-headline">For Suppliers</h4>
                  <p class="text-secondary text-sm">
                    Enhance your credibility through certified compliance and connect with tier-one industrial partners.
                  </p>
                </div>
              </div>
              <div class="flex gap-6">
                <span class="text-primary-container font-black text-2xl font-headline">02</span>
                <div>
                  <h4 class="font-bold text-lg text-primary-container mb-2 font-headline">For Mid-Sized Companies</h4>
                  <p class="text-secondary text-sm">
                    Companies that need stronger systems, compliance, and growth structure.
                  </p>
                </div>
              </div>
              <div class="flex gap-6">
                <span class="text-primary-container font-black text-2xl font-headline">03</span>
                <div>
                  <h4 class="font-bold text-lg text-primary-container mb-2 font-headline">For Business Owners</h4>
                  <p class="text-secondary text-sm">
                    Business owners preparing for investment, scale-up, or long-term strategic positioning.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <div class="relative">
            <div class="aspect-[4/3] bg-surface-container rounded-xl overflow-hidden">
              <img src="/images/hero-team.svg" alt="Curator team" class="w-full h-full object-cover" loading="lazy" />
            </div>
            <div class="absolute -bottom-6 -right-6 bg-primary-container text-white p-8 rounded-lg max-w-xs ambient-shadow hidden md:block">
              <p class="text-sm italic mb-4">"Curator redefined our compliance roadmap, saving us months of regulatory friction."</p>
              <p class="font-bold text-xs uppercase tracking-widest">— CTO, Global Industrial Corp</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How We Work Section -->
    <section class="py-20 md:py-24 px-6 md:px-8 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">The Methodology</span>
          <h2 class="text-4xl font-extrabold text-primary-container font-headline">A Protocol for Precision</h2>
        </div>
        <div class="relative">
          <div class="absolute top-1/2 left-0 w-full h-[1px] bg-outline-variant/20 hidden lg:block"></div>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <div class="relative bg-surface-container-lowest p-8 rounded-xl ghost-border z-10 hover:-translate-y-2 transition-transform">
              <div class="w-10 h-10 rounded-full bg-secondary text-white flex items-center justify-center font-bold mb-6">1</div>
              <h4 class="text-xl font-bold mb-4 font-headline">Assess</h4>
              <p class="text-secondary text-sm">We review the current situation, goals, constraints, and opportunity areas.</p>
            </div>
            <div class="relative bg-surface-container-lowest p-8 rounded-xl ghost-border z-10 hover:-translate-y-2 transition-transform">
              <div class="w-10 h-10 rounded-full bg-secondary text-white flex items-center justify-center font-bold mb-6">2</div>
              <h4 class="text-xl font-bold mb-4 font-headline">Plan</h4>
              <p class="text-secondary text-sm">We define a practical roadmap with clear priorities and the right service mix.</p>
            </div>
            <div class="relative bg-surface-container-lowest p-8 rounded-xl ghost-border z-10 hover:-translate-y-2 transition-transform">
              <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold mb-6">3</div>
              <h4 class="text-xl font-bold mb-4 font-headline">Execute</h4>
              <p class="text-secondary text-sm">We coordinate delivery through in-house advisory scope and specialist solution partners.</p>
            </div>
            <div class="relative bg-surface-container-lowest p-8 rounded-xl ghost-border z-10 hover:-translate-y-2 transition-transform">
              <div class="w-10 h-10 rounded-full bg-secondary text-white flex items-center justify-center font-bold mb-6">4</div>
              <h4 class="text-xl font-bold mb-4 font-headline">Improve</h4>
              <p class="text-secondary text-sm">We support readiness, progress tracking, and next-stage planning.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Section -->
    <section class="py-20 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <p class="text-center text-xs font-bold tracking-[0.3em] text-on-surface-variant uppercase mb-12">
          Trusted by Global Infrastructure Leaders
        </p>
        <div class="flex flex-wrap justify-center gap-12 md:gap-24 opacity-60">
          <div class="text-2xl font-black text-primary-container italic font-headline">SIEMENS</div>
          <div class="text-2xl font-black text-primary-container font-headline">LOGITECH</div>
          <div class="text-2xl font-black text-primary-container font-headline">RAYTHEON</div>
          <div class="text-2xl font-black text-primary-container italic font-headline">AIRBUS</div>
          <div class="text-2xl font-black text-primary-container font-headline">ABB</div>
        </div>
      </div>
    </section>

    <!-- Final CTA Section -->
    <section class="py-20 md:py-24 px-6 md:px-8 bg-surface">
      <div class="max-w-5xl mx-auto rounded-3xl signature-gradient p-12 md:p-20 text-center relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6 font-headline">Ready to scale your business?</h2>
          <p class="text-white/70 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
            Join the ecosystem of precision-driven industrial companies building the future.
          </p>
          <a
            href="/en/contact/"
            class="inline-block bg-white text-primary-container px-12 py-5 rounded-lg font-black text-lg hover:bg-surface-container-low transition-all"
          >
            Contact Our Experts
          </a>
        </div>
        <div class="absolute -top-24 -left-24 w-64 h-64 bg-white/5 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-secondary-container/10 rounded-full blur-3xl"></div>
      </div>
    </section>
  </main>
</BaseLayout>
