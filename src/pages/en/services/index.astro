---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    icon: 'public',
    title: 'Strategic Growth & Market Development',
    description: 'We support companies that want to enter new sectors, reach new customer groups, or build a more focused growth strategy.',
    href: '/en/services/strategic-growth/',
    span: 'md:col-span-3',
  },
  {
    icon: 'inventory',
    title: 'Supplier Development & Audit',
    description: 'We help suppliers understand where they stand, close critical gaps, and prepare for stricter customer expectations.',
    href: '/en/services/supplier-development/',
    span: 'md:col-span-3',
  },
  {
    icon: 'security',
    title: 'Compliance & Information Security',
    description: 'KVKK support, ISO 27001 readiness and implementation support, documentation structure.',
    href: '/en/services/compliance-security/',
    span: 'md:col-span-2',
  },
  {
    icon: 'cloud',
    title: 'IT, Network & Cloud Solutions',
    description: 'Network infrastructure, cloud transition planning, system modernization, and operational IT needs analysis.',
    href: '/en/services/it-cloud-solutions/',
    span: 'md:col-span-2',
  },
  {
    icon: 'account_balance',
    title: 'Financial & Strategic Advisory',
    description: 'Company valuation, strategic planning, growth scenario planning, and investment readiness.',
    href: '/en/services/financial-advisory/',
    span: 'md:col-span-2',
  },
];
---

<BaseLayout
  title="Services | CURATOR B2B Consultancy"
  description="Integrated solutions for sustainable business growth: strategy, supplier development, compliance, IT/cloud, and financial advisory."
  locale="en"
>
  <main class="pt-20">
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-7xl mx-auto grid md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-8">
          <span class="text-xs tracking-widest uppercase text-on-primary-container font-bold mb-4 block">Service Portfolio</span>
          <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tight leading-tight text-primary-container">
            Integrated Solutions for <span class="text-on-tertiary-container">Sustainable Growth.</span>
          </h1>
        </div>
        <div class="md:col-span-4 pb-4">
          <p class="text-on-surface-variant leading-relaxed text-lg">
            From market strategy to audit readiness, from IT enablement to strategic finance, we help companies build the capabilities needed for the next stage of growth.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <p class="text-lg text-secondary leading-relaxed max-w-4xl">
          Our services are designed to work together. A company may enter through one need, but long-term value often comes from solving connected issues across growth, systems, readiness, and strategic direction.
        </p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-6 gap-6">
          {services.map((service) => (
            <a href={service.href} class={`${service.span} bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all group`}>
              <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">{service.icon}</span>
              <h4 class="text-xl font-bold mb-4 font-headline text-primary-container group-hover:text-on-tertiary-container transition-colors">{service.title}</h4>
              <p class="text-secondary text-sm leading-relaxed mb-6">{service.description}</p>
              <span class="text-primary-container font-semibold text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
                Learn More
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold text-primary-container mb-6 font-headline">Need Help Identifying the Right Starting Point?</h2>
        <p class="text-secondary mb-10">We can map your priorities in an initial meeting.</p>
        <a href="/en/contact/" class="inline-block signature-gradient text-white px-10 py-4 rounded-lg font-bold text-lg ambient-shadow hover:opacity-95 transition-all">
          Book a Meeting
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
