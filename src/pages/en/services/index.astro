---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    icon: 'public',
    title: 'Strategic Growth & Market Development',
    description: 'We support companies that want to enter new sectors, reach new customer groups, or build a more focused growth strategy.',
    href: '/en/services/strategic-growth/',
    features: ['Market Analysis', 'Growth Strategy', 'Competitive Mapping'],
  },
  {
    icon: 'inventory',
    title: 'Supplier Development & Audit',
    description: 'We help suppliers understand where they stand, close critical gaps, and prepare for stricter customer expectations.',
    href: '/en/services/supplier-development/',
    features: ['Gap Analysis', 'Audit Readiness', 'Process Improvement'],
  },
  {
    icon: 'security',
    title: 'Compliance & Information Security',
    description: 'KVKK support, ISO 27001 readiness and implementation support, documentation structure.',
    href: '/en/services/compliance-security/',
    features: ['KVKK', 'ISO 27001', 'Documentation'],
  },
  {
    icon: 'cloud',
    title: 'IT, Network & Cloud Solutions',
    description: 'Network infrastructure, cloud transition planning, system modernization, and operational IT needs analysis.',
    href: '/en/services/it-cloud-solutions/',
    features: ['Cloud Migration', 'Infrastructure', 'Integration'],
  },
  {
    icon: 'account_balance',
    title: 'Financial & Strategic Advisory',
    description: 'Company valuation, strategic planning, growth scenario planning, and investment readiness.',
    href: '/en/services/financial-advisory/',
    features: ['Valuation', 'Investment Readiness', 'Planning'],
  },
];
---

<BaseLayout
  title="Services | CURATOR B2B Consultancy"
  description="Integrated solutions for sustainable business growth: strategy, supplier development, compliance, IT/cloud, and financial advisory."
  locale="en"
>
  <main>
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="grid md:grid-cols-12 gap-8 items-end">
          <div class="md:col-span-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Service Portfolio</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display">
              Integrated Solutions for Sustainable Growth.
            </h1>
          </div>
          <div class="md:col-span-4 pb-2">
            <p class="text-on-dark-secondary leading-relaxed">
              From market strategy to audit readiness, from IT enablement to strategic finance, we help companies build the capabilities needed for the next stage of growth.
            </p>
          </div>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="space-y-6">
          {services.map((service, i) => (
            <a href={service.href} class="card-light rounded-2xl p-8 md:p-12 group block">
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                <div class="lg:col-span-1">
                  <div class="w-14 h-14 rounded-xl bg-navy flex items-center justify-center">
                    <span class="material-symbols-outlined text-gold text-2xl">{service.icon}</span>
                  </div>
                </div>
                <div class="lg:col-span-7">
                  <div class="flex items-center gap-3 mb-3">
                    <span class="stat-number text-sm font-bold tracking-widest">{`0${i + 1}`}</span>
                    <div class="w-8 h-[1px] bg-gold/40"></div>
                  </div>
                  <h3 class="text-2xl md:text-3xl font-extrabold text-heading mb-4 font-display group-hover:text-gold transition-colors">
                    {service.title}
                  </h3>
                  <p class="text-body leading-relaxed">{service.description}</p>
                </div>
                <div class="lg:col-span-4 lg:border-l lg:border-border lg:pl-8">
                  <p class="text-xs uppercase tracking-widest text-muted font-bold mb-4">Scope</p>
                  <ul class="space-y-2">
                    {service.features.map((f) => (
                      <li class="flex items-center gap-2 text-sm text-body">
                        <span class="w-1 h-1 rounded-full bg-gold"></span>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <div class="mt-6 flex items-center gap-2 text-gold font-semibold text-sm group-hover:gap-3 transition-all">
                    Learn More
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 md:py-32 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6 font-display">
          Need Help Identifying the Right Starting Point?
        </h2>
        <p class="text-on-dark-secondary mb-10">We can map your priorities in an initial meeting.</p>
        <a href="/en/contact/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Book a Meeting
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
