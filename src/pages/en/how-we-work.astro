---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="How We Work | CURATOR" description="A clear method from assessment to execution." locale="en">
  <main class="pt-20">
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <span class="text-xs tracking-widest uppercase text-on-primary-container font-bold mb-6 block">Our Methodology</span>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
            A Clear Method from <br /><span class="text-secondary">Assessment to Execution.</span>
          </h1>
          <p class="text-lg text-on-surface-variant leading-relaxed max-w-xl">
            We start with the business need, define priorities, and coordinate the right capabilities to move the company forward.
          </p>
        </div>
        <div class="lg:col-span-5">
          <img src="/images/methodology.svg" alt="Methodology process" class="w-full rounded-xl" loading="eager" />
        </div>
      </div>
    </section>

    <section class="bg-surface-container-low py-20 md:py-24 px-6 md:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { num: '01', title: 'Assess', desc: 'We review the current situation, goals, constraints, and opportunity areas.', tags: ['Risk Audit', 'Data Synthesis'] },
            { num: '02', title: 'Plan', desc: 'We define a practical roadmap with clear priorities and the right service mix.', tags: ['Strategy Mapping', 'Compliance Path'] },
            { num: '03', title: 'Execute', desc: 'We coordinate delivery through in-house advisory scope and specialist solution partners.', tags: ['Tech Integration', 'Change Mgmt'] },
            { num: '04', title: 'Improve', desc: 'We support readiness, progress tracking, and next-stage planning.', tags: ['Market Capture', 'Continuous Growth'] },
          ].map((step, i) => (
            <div class={`bg-surface-container-lowest p-10 rounded-xl group hover:ambient-shadow transition-all flex flex-col h-full ${i === 2 ? 'border-t-4 border-primary' : ''}`}>
              <div class="mb-12">
                <span class="text-6xl font-black text-outline-variant/20 group-hover:text-secondary/20 transition-colors font-headline">{step.num}</span>
                <h3 class="text-2xl font-bold text-primary-container mt-4 font-headline">{step.title}</h3>
              </div>
              <p class="text-on-surface-variant mb-12 flex-grow text-sm leading-relaxed">{step.desc}</p>
              <div class="space-y-3 pt-6 border-t border-outline-variant/10">
                {step.tags.map((tag) => (
                  <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-wider text-secondary">
                    <span class="w-1.5 h-1.5 bg-on-tertiary-container rounded-full"></span>
                    {tag}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Statement -->
    <section class="py-20 px-6 md:px-8 signature-gradient">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-white text-xl md:text-2xl font-bold leading-relaxed font-headline">
          "Process discipline, precise timing, and coordinated execution — these three form the foundation of growth."
        </p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold text-primary-container mb-8 font-headline">Plan an Initial Assessment</h2>
        <p class="text-lg text-on-surface-variant max-w-2xl mx-auto mb-12">
          Schedule a preliminary consultation to see how our 4-step framework can be applied to your unique industrial ecosystem.
        </p>
        <a href="/en/contact/" class="signature-gradient text-white px-10 py-4 rounded-lg font-bold hover:opacity-95 transition-all text-lg inline-block">
          Book a Meeting
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
