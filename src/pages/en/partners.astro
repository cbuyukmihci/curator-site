---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Partners | CURATOR" description="Specialized expertise, coordinated through one platform." locale="en">
  <main class="pt-20">
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-4xl">
        <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">Partner Ecosystem</span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">Specialized Expertise, Coordinated Through One Platform.</h1>
        <p class="text-lg text-secondary leading-relaxed">Our model combines commercial coordination with specialist execution where required. This gives clients access to broader capability without the burden of fragmented vendor management.</p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-surface-container-lowest p-10 rounded-xl ghost-border">
          <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">cloud</span>
          <h3 class="text-xl font-bold text-primary-container mb-4 font-headline">Technology Partners</h3>
          <p class="text-secondary text-sm leading-relaxed">Network, systems, infrastructure, and cloud capabilities delivered through trusted specialist partners.</p>
        </div>
        <div class="bg-surface-container-lowest p-10 rounded-xl ghost-border">
          <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">security</span>
          <h3 class="text-xl font-bold text-primary-container mb-4 font-headline">Compliance Partners</h3>
          <p class="text-secondary text-sm leading-relaxed">KVKK and ISO 27001 expertise provided through experienced professionals.</p>
        </div>
        <div class="bg-surface-container-lowest p-10 rounded-xl ghost-border">
          <span class="material-symbols-outlined text-primary-container mb-6 block text-3xl">account_balance</span>
          <h3 class="text-xl font-bold text-primary-container mb-4 font-headline">Finance Partners</h3>
          <p class="text-secondary text-sm leading-relaxed">Valuation, strategic planning, and introductory capital-market readiness support through trusted financial specialists.</p>
        </div>
      </div>
    </section>

    <section class="py-16 px-6 md:px-8 bg-surface">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-xl text-primary-container font-bold font-headline">One relationship, multiple capabilities, stronger execution alignment.</p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold text-primary-container mb-6 font-headline">Explore Partnership-Led Solutions</h2>
        <a href="/en/contact/" class="inline-block signature-gradient text-white px-10 py-4 rounded-lg font-bold text-lg ambient-shadow hover:opacity-95 transition-all">Book a Meeting</a>
      </div>
    </section>
  </main>
</BaseLayout>
