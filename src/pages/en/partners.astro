---
import BaseLayout from '../../layouts/BaseLayout.astro';

const partners = [
  { icon: 'cloud', title: 'Technology Partners', desc: 'Network, systems, infrastructure, and cloud capabilities delivered through trusted specialist partners.' },
  { icon: 'security', title: 'Compliance Partners', desc: 'KVKK and ISO 27001 expertise provided through experienced professionals.' },
  { icon: 'account_balance', title: 'Finance Partners', desc: 'Valuation, strategic planning, and introductory capital-market readiness support through trusted financial specialists.' },
];
---

<BaseLayout title="Partners | CURATOR" description="Specialized expertise, coordinated through one platform." locale="en">
  <main>
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Partner Ecosystem</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display mb-6">
            Specialized Expertise, Coordinated Through One Platform.
          </h1>
          <p class="text-on-dark-secondary text-lg leading-relaxed">
            Our model combines commercial coordination with specialist execution where required, giving clients access to broader capability without fragmented vendor management.
          </p>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {partners.map((p) => (
            <div class="card-light rounded-xl p-8">
              <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-gold text-xl">{p.icon}</span>
              </div>
              <h3 class="text-xl font-bold text-heading mb-4 font-display">{p.title}</h3>
              <p class="text-body text-sm leading-relaxed">{p.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-20 md:py-24 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <div class="flex justify-center mb-8">
          <div class="accent-line"></div>
        </div>
        <p class="text-white text-xl md:text-2xl font-bold leading-relaxed font-display">
          One relationship, multiple capabilities, stronger execution alignment.
        </p>
      </div>
    </section>

    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight font-display mb-4">Explore Partnership-Led Solutions</h2>
        <p class="text-body mb-10">Let's plan the right combination of capabilities for your needs together.</p>
        <a href="/en/contact/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Book a Meeting
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
