---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About | CURATOR" description="A strategic platform built for growth, readiness, and transformation." locale="en">
  <main class="pt-20">
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-4xl">
        <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">About Us</span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
          A Strategic Platform Built for Growth, Readiness, and Transformation.
        </h1>
        <p class="text-lg text-on-surface-variant leading-relaxed max-w-3xl">
          Today, companies need more than a good product. They need structure, compliance, systems, and market access. We bring these elements together under one roof.
        </p>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="py-12 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-primary-container font-headline">50+</div>
          <div class="text-sm text-on-surface-variant mt-1">Expert Team</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-primary-container font-headline">4</div>
          <div class="text-sm text-on-surface-variant mt-1">Industry Focus</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-primary-container font-headline">5</div>
          <div class="text-sm text-on-surface-variant mt-1">Service Areas</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-extrabold text-primary-container font-headline">2</div>
          <div class="text-sm text-on-surface-variant mt-1">Regional Offices</div>
        </div>
      </div>
    </section>

    <section class="py-16 md:py-20 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-3xl font-extrabold text-primary-container mb-8 font-headline">What We Do</h2>
          <p class="text-on-surface-variant leading-relaxed mb-6">
            We work with industrial, defense, technology, and growth-focused businesses that want to strengthen their market position and become ready for larger opportunities.
          </p>
          <p class="text-on-surface-variant leading-relaxed">
            Our model combines strategic advisory, supplier development, compliance support, IT/cloud enablement, and strategic finance coordination.
          </p>
        </div>
        <div>
          <h2 class="text-3xl font-extrabold text-primary-container mb-8 font-headline">Why This Model Matters</h2>
          <p class="text-on-surface-variant leading-relaxed mb-6">
            Many companies do not fail because of product weakness. They stall because they lack the systems, structure, documentation, or market strategy needed to move forward.
          </p>
          <p class="text-on-surface-variant leading-relaxed">
            We help close those gaps with an integrated, execution-oriented approach.
          </p>
        </div>
      </div>
    </section>

    <!-- Visual Break -->
    <section class="py-0 bg-surface">
      <div class="max-w-7xl mx-auto px-6 md:px-8">
        <img src="/images/office.jpg" alt="Curator office" class="w-full h-64 md:h-80 object-cover rounded-xl grayscale opacity-90 hover:grayscale-0 hover:opacity-100 transition-all duration-700" loading="lazy" />
      </div>
    </section>

    <!-- Positioning Statement -->
    <section class="py-20 px-6 md:px-8 signature-gradient">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-white text-xl md:text-2xl font-bold leading-relaxed font-headline">
          "We help companies grow, comply, and become ready for major ecosystems."
        </p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold text-primary-container mb-6 font-headline">Talk to Us</h2>
        <p class="text-secondary mb-10">Let's discuss your company's growth and readiness priorities together.</p>
        <a href="/en/contact/" class="inline-block signature-gradient text-white px-10 py-4 rounded-lg font-bold text-lg ambient-shadow hover:opacity-95 transition-all">
          Book a Meeting
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
