---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="About | CURATOR" description="A strategic platform built for growth, readiness, and transformation." locale="en">
  <main>
    <!-- Hero -->
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">About Us</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display mb-6">
            A Strategic Platform Built for Growth, Readiness, and Transformation.
          </h1>
          <p class="text-on-dark-secondary text-lg leading-relaxed max-w-2xl">
            Today, companies need more than a good product. They need structure, compliance, systems, and market access.
          </p>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <!-- Stats -->
    <section class="bg-navy-light border-t border-navy-border">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { num: '50+', label: 'Expert Team' },
            { num: '4', label: 'Industry Focus' },
            { num: '5', label: 'Service Areas' },
            { num: '2', label: 'Regional Offices' },
          ].map((s) => (
            <div class="text-center">
              <div class="stat-number text-3xl md:text-4xl mb-1">{s.num}</div>
              <div class="text-on-dark-secondary text-sm">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What We Do -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">What We Do</span>
            </div>
            <h2 class="text-3xl font-extrabold tracking-tight font-display mb-6">An Integrated Model for Industrial Growth</h2>
            <p class="text-body leading-relaxed mb-4">
              We work with industrial, defense, technology, and growth-focused businesses that want to strengthen their market position and become ready for larger opportunities.
            </p>
            <p class="text-body leading-relaxed">
              Our model combines strategic advisory, supplier development, compliance support, IT/cloud enablement, and strategic finance coordination.
            </p>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Why This Model</span>
            </div>
            <h2 class="text-3xl font-extrabold tracking-tight font-display mb-6">Structural Gaps Stall Growth</h2>
            <p class="text-body leading-relaxed mb-4">
              Many companies do not fail because of product weakness. They stall because they lack the systems, structure, documentation, or market strategy needed to move forward.
            </p>
            <p class="text-body leading-relaxed">
              We help close those gaps with an integrated, execution-oriented approach.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Visual -->
    <section class="bg-slate">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6">
        <img src="/images/office.jpg" alt="Curator office" class="w-full h-72 md:h-96 object-cover rounded-2xl" loading="lazy" />
      </div>
    </section>

    <!-- Quote -->
    <section class="py-20 md:py-24 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <div class="flex justify-center mb-8">
          <div class="w-8 h-8 rounded-full bg-gold/20 flex items-center justify-center">
            <span class="text-gold text-lg">"</span>
          </div>
        </div>
        <p class="text-white text-xl md:text-2xl font-bold leading-relaxed font-display">
          We help companies grow, comply, and become ready for major ecosystems.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight font-display mb-4">Talk to Us</h2>
        <p class="text-body mb-10">Let's discuss your company's growth and readiness priorities together.</p>
        <a href="/en/contact/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Book a Meeting
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
