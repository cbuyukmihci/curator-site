---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('insights');
const posts = allPosts
  .filter((post) => post.data.locale === 'en')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Insights | CURATOR" description="Practical insights for companies preparing to grow." locale="en">
  <main>
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Insights</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display mb-6">
            Practical Insights for Companies Preparing to Grow.
          </h1>
          <p class="text-on-dark-secondary text-lg leading-relaxed">
            Our insights section shares practical guidance on growth, readiness, compliance, supplier development, and strategic business preparation.
          </p>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/en/insights/${post.id.replace('en/', '')}/`} class="card-light rounded-xl p-8 group flex flex-col">
              <div class="flex gap-2 mb-5">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-[10px] font-bold uppercase tracking-widest text-gold bg-gold/10 px-2 py-1 rounded">{tag}</span>
                ))}
              </div>
              <h3 class="text-lg font-bold text-heading mb-3 font-display group-hover:text-gold transition-colors flex-grow">
                {post.data.title}
              </h3>
              <p class="text-body text-sm leading-relaxed mb-6">{post.data.description}</p>
              <div class="flex items-center justify-between pt-5 border-t border-border mt-auto">
                <span class="text-xs text-muted">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="material-symbols-outlined text-gold text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </a>
          ))}
        </div>

        {posts.length === 0 && (
          <p class="text-center text-body text-lg py-12">No published articles yet.</p>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
