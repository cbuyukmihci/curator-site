---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('insights');
const posts = allPosts
  .filter((post) => post.data.locale === 'en')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Insights | CURATOR" description="Practical insights for companies preparing to grow." locale="en">
  <main class="pt-20">
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-4xl">
        <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">Insights</span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
          Practical Insights for Companies Preparing to Grow.
        </h1>
        <p class="text-lg text-secondary leading-relaxed">
          Our insights section shares practical guidance on growth, readiness, compliance, supplier development, and strategic business preparation.
        </p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a href={`/en/insights/${post.id.replace('en/', '')}/`} class="bg-surface-container-lowest p-8 rounded-xl ghost-border hover:ambient-shadow transition-all group flex flex-col">
              <div class="flex gap-2 mb-4">
                {post.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-[10px] font-bold uppercase tracking-widest text-on-primary-container bg-surface-container-low px-2 py-1 rounded">{tag}</span>
                ))}
              </div>
              <h3 class="text-lg font-bold text-primary-container mb-3 font-headline group-hover:text-on-tertiary-container transition-colors flex-grow">
                {post.data.title}
              </h3>
              <p class="text-secondary text-sm leading-relaxed mb-4">{post.data.description}</p>
              <div class="flex items-center justify-between mt-auto pt-4 border-t border-outline-variant/10">
                <span class="text-xs text-on-surface-variant">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="material-symbols-outlined text-primary-container text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </div>
            </a>
          ))}
        </div>

        {posts.length === 0 && (
          <p class="text-center text-secondary text-lg py-12">No published articles yet.</p>
        )}
      </div>
    </section>
  </main>
</BaseLayout>
