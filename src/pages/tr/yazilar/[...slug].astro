---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('insights');
  const trPosts = allPosts.filter((post) => post.data.locale === 'tr');
  return trPosts.map((post) => ({
    params: { slug: post.id.replace('tr/', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | CURATOR`} description={post.data.description} locale="tr">
  <main>
    <!-- Hero -->
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-12 pt-32 pb-16 md:pt-40 md:pb-20 relative z-10">
        <a href="/tr/yazilar/" class="text-xs font-bold uppercase tracking-widest text-gold hover:text-gold-light transition-colors inline-flex items-center gap-1 mb-8">
          <span class="material-symbols-outlined text-sm">arrow_back</span>
          Tüm Yazılar
        </a>
        <div class="flex gap-2 mb-6">
          {post.data.tags.map((tag) => (
            <span class="text-[10px] font-bold uppercase tracking-widest text-gold bg-gold/10 border border-gold/20 px-2 py-1 rounded">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight leading-[1.15] font-display mb-6">
          {post.data.title}
        </h1>
        <div class="flex items-center gap-3 text-sm text-on-dark-secondary">
          <span>{post.data.author}</span>
          <span class="w-1 h-1 bg-on-dark-muted rounded-full"></span>
          <span>{post.data.date.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        </div>
      </div>
    </section>

    <!-- Content -->
    <article class="py-24 bg-white">
      <div class="max-w-3xl mx-auto px-6 lg:px-12">
        <div class="prose prose-lg max-w-none
          prose-headings:font-display prose-headings:text-heading prose-headings:tracking-tight
          prose-p:text-body prose-p:leading-relaxed
          prose-a:text-gold prose-a:no-underline hover:prose-a:underline
          prose-strong:text-heading
          prose-li:text-body
          prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        ">
          <Content />
        </div>

        <!-- CTA -->
        <div class="mt-16 card-light rounded-2xl p-10 text-center">
          <p class="text-heading font-bold mb-6 font-display text-lg">Bu konuda destek almak ister misiniz?</p>
          <a href="/tr/iletisim/" class="btn-gold px-8 py-3 rounded-lg text-sm inline-block">
            Toplantı Planla
          </a>
        </div>
      </div>
    </article>
  </main>
</BaseLayout>
