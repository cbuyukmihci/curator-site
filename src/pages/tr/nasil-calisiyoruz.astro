---
import BaseLayout from '../../layouts/BaseLayout.astro';

const steps = [
  { num: '01', title: 'Değerlendir', desc: 'Mevcut durumu, hedefleri, kısıtlamaları ve fırsat alanlarını inceliyoruz.', tags: ['Risk Analizi', 'Veri Sentezi'] },
  { num: '02', title: 'Planla', desc: 'Net öncelikler ve doğru hizmet karışımı ile pratik bir yol haritası tanımlıyoruz.', tags: ['Strateji Haritası', 'Uyumluluk Yolu'] },
  { num: '03', title: 'Uygula', desc: 'Kurum içi danışmanlık ve uzman çözüm ortakları aracılığıyla uygulamayı koordine ediyoruz.', tags: ['Teknoloji Entegrasyonu', 'Değişim Yönetimi'] },
  { num: '04', title: 'İyileştir', desc: 'Hazırlık, ilerleme takibi ve sonraki aşama planlamasını destekliyoruz.', tags: ['Pazar Kazanımı', 'Sürekli Gelişim'] },
];
---

<BaseLayout title="Nasıl Çalışıyoruz | CURATOR" description="Değerlendirmeden uygulamaya net bir metodoloji." locale="tr">
  <main>
    <!-- Hero -->
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Metodolojimiz</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display mb-6">
            Değerlendirmeden Uygulamaya Net Bir Yol.
          </h1>
          <p class="text-on-dark-secondary text-lg leading-relaxed max-w-2xl">
            İş ihtiyacından başlıyoruz, öncelikleri belirliyoruz ve şirketi ileriye taşımak için doğru yetkinlikleri koordine ediyoruz.
          </p>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <!-- Steps -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map((step, i) => (
            <div class={`card-light rounded-xl p-8 relative ${i === 2 ? 'border-t-2 border-t-gold' : ''}`}>
              <span class="stat-number text-5xl font-extrabold block mb-6">{step.num}</span>
              <h3 class="text-xl font-bold text-heading mb-3 font-display">{step.title}</h3>
              <p class="text-body text-sm leading-relaxed mb-6">{step.desc}</p>
              <div class="space-y-2 pt-4 border-t border-border">
                {step.tags.map((tag) => (
                  <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-muted">
                    <span class="w-1 h-1 bg-gold rounded-full"></span>
                    {tag}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Statement -->
    <section class="py-20 md:py-24 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <p class="text-white text-xl md:text-2xl font-bold leading-relaxed font-display">
          Süreç disiplini, doğru zamanlama ve koordineli uygulama — büyümenin temelini bu üçlü oluşturur.
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-3xl font-extrabold tracking-tight font-display mb-4">İlk Değerlendirmeyi Planlayın</h2>
        <p class="text-body mb-10">4 aşamalı çerçevemizin şirketinize nasıl uygulanabileceğini görmek için bir ön görüşme planlayın.</p>
        <a href="/tr/iletisim/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Toplantı Planla
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
