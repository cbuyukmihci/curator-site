---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Nasıl Çalışıyoruz | CURATOR" description="Değerlendirmeden uygulamaya net bir metodoloji." locale="tr">
  <main class="pt-20">
    <!-- Hero -->
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <span class="text-xs tracking-widest uppercase text-on-primary-container font-bold mb-6 block">Metodolojimiz</span>
          <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
            Değerlendirmeden <br /><span class="text-secondary">Uygulamaya Net Bir Yol.</span>
          </h1>
          <p class="text-lg text-on-surface-variant leading-relaxed max-w-xl">
            İş ihtiyacından başlıyoruz, öncelikleri belirliyoruz ve şirketi ileriye taşımak için doğru yetkinlikleri koordine ediyoruz.
          </p>
        </div>
        <div class="lg:col-span-5 flex justify-center">
          <div class="bg-surface-container-lowest p-8 rounded-lg ambient-shadow ghost-border">
            <div class="text-primary-container font-bold text-4xl mb-2 font-headline">4</div>
            <div class="text-xs tracking-widest uppercase text-on-surface-variant font-bold">Aşamalı Süreç</div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4-Step Methodology -->
    <section class="bg-surface-container-low py-32 px-6 md:px-8">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { num: '01', title: 'Değerlendir', desc: 'Mevcut durumu, hedefleri, kısıtlamaları ve fırsat alanlarını inceliyoruz.', tags: ['Risk Analizi', 'Veri Sentezi'] },
            { num: '02', title: 'Planla', desc: 'Net öncelikler ve doğru hizmet karışımı ile pratik bir yol haritası tanımlıyoruz.', tags: ['Strateji Haritası', 'Uyumluluk Yolu'] },
            { num: '03', title: 'Uygula', desc: 'Kurum içi danışmanlık ve uzman çözüm ortakları aracılığıyla uygulamayı koordine ediyoruz.', tags: ['Teknoloji Entegrasyonu', 'Değişim Yönetimi'] },
            { num: '04', title: 'İyileştir', desc: 'Hazırlık, ilerleme takibi ve sonraki aşama planlamasını destekliyoruz.', tags: ['Pazar Kazanımı', 'Sürekli Gelişim'] },
          ].map((step, i) => (
            <div class={`bg-surface-container-lowest p-10 rounded-xl group hover:ambient-shadow transition-all flex flex-col h-full ${i === 2 ? 'border-t-4 border-primary' : ''}`}>
              <div class="mb-12">
                <span class="text-6xl font-black text-outline-variant/20 group-hover:text-secondary/20 transition-colors font-headline">{step.num}</span>
                <h3 class="text-2xl font-bold text-primary-container mt-4 font-headline">{step.title}</h3>
              </div>
              <p class="text-on-surface-variant mb-12 flex-grow text-sm leading-relaxed">{step.desc}</p>
              <div class="space-y-3 pt-6 border-t border-outline-variant/10">
                {step.tags.map((tag) => (
                  <div class="flex items-center gap-3 text-xs font-bold uppercase tracking-wider text-secondary">
                    <span class="w-1.5 h-1.5 bg-on-tertiary-container rounded-full"></span>
                    {tag}
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 px-6 md:px-8 bg-surface">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-extrabold text-primary-container mb-8 font-headline">İlk Değerlendirmeyi Planlayın</h2>
        <p class="text-lg text-on-surface-variant max-w-2xl mx-auto mb-12">
          4 aşamalı çerçevemizin benzersiz endüstriyel ekosistemine nasıl uygulanabileceğini görmek için bir ön görüşme planlayın.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/tr/iletisim/" class="signature-gradient text-white px-10 py-4 rounded-lg font-bold hover:opacity-95 transition-all text-lg">
            Toplantı Planla
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
