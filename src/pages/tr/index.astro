---
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  { icon: 'public', title: 'Stratejik Büyüme', desc: 'Yeni pazarlara giriş, müşteri segmentasyonu ve büyüme yol haritası oluşturma.', href: '/tr/hizmetler/stratejik-buyume/' },
  { icon: 'inventory', title: 'Tedarikçi Geliştirme', desc: 'Tedarikçi değerlendirme, açık analizi ve denetim hazırlığı.', href: '/tr/hizmetler/tedarikci-gelistirme/' },
  { icon: 'security', title: 'Uyumluluk & Güvenlik', desc: 'KVKK, ISO 27001 hazırlığı ve bilgi güvenliği yapılandırması.', href: '/tr/hizmetler/uyumluluk-bilgi-guvenligi/' },
  { icon: 'cloud', title: 'IT & Bulut Çözümleri', desc: 'Altyapı modernizasyonu, bulut geçişi ve sistem entegrasyonu.', href: '/tr/hizmetler/it-bulut-cozumleri/' },
  { icon: 'account_balance', title: 'Finansal Danışmanlık', desc: 'Şirket değerleme, yatırıma hazırlık ve stratejik planlama.', href: '/tr/hizmetler/finansal-danismanlik/' },
];

const stats = [
  { number: '50+', label: 'Uzman Kadro' },
  { number: '4', label: 'Sektör Odağı' },
  { number: '5', label: 'Hizmet Alanı' },
  { number: '150+', label: 'Tamamlanan Proje' },
];

const steps = [
  { num: '01', title: 'Değerlendir', desc: 'Mevcut durum, hedefler ve fırsat alanlarını analiz ediyoruz.' },
  { num: '02', title: 'Planla', desc: 'Net önceliklerle pratik bir yol haritası oluşturuyoruz.' },
  { num: '03', title: 'Uygula', desc: 'Uzman ekipler ve çözüm ortaklarıyla uygulamaya geçiriyoruz.' },
  { num: '04', title: 'İyileştir', desc: 'Sürekli takip ve gelişim desteği sağlıyoruz.' },
];
---

<BaseLayout
  title="CURATOR | Büyüme, Uyumluluk ve Stratejik Danışmanlık"
  description="Endüstriyel, savunma ve teknoloji odaklı şirketlere pazar geliştirme, tedarikçi hazırlığı, uyumluluk, IT/bulut ve stratejik finans çözümleri sunuyoruz."
  locale="tr"
>
  <main>
    <!-- ═══ HERO ═══ -->
    <section class="relative bg-hero min-h-[90vh] flex items-center overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-32 md:py-40 relative z-10 w-full">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-8">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">B2B Stratejik Danışmanlık</span>
          </div>
          <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.08] tracking-tight font-display mb-8">
            Büyüyün. Uyum Sağlayın.
            <span class="block text-on-dark-secondary">Daha Büyük Fırsatlara Hazır Olun.</span>
          </h1>
          <p class="text-on-dark-secondary text-lg md:text-xl leading-relaxed max-w-2xl mb-12">
            Endüstriyel, savunma ve teknoloji odaklı şirketlere pazar geliştirme, tedarikçi hazırlığı, uyumluluk ve stratejik finans çözümleri sunuyoruz.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/tr/iletisim/" class="btn-gold px-8 py-4 rounded-lg text-base text-center">
              Toplantı Planla
            </a>
            <a href="/tr/hizmetler/" class="btn-ghost-light px-8 py-4 rounded-lg text-base text-center">
              Hizmetleri Keşfet
            </a>
          </div>
        </div>
      </div>

      <!-- Decorative orbs -->
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
      <div class="absolute bottom-20 right-[30%] w-96 h-96 bg-blue-500/5 rounded-full blur-[120px]"></div>
    </section>

    <!-- ═══ STATS BAR ═══ -->
    <section class="bg-navy-light border-t border-navy-border">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 md:py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="stat-number text-4xl md:text-5xl mb-2">{stat.number}</div>
              <div class="text-on-dark-secondary text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ SERVICES ═══ -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-16">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Hizmetlerimiz</span>
            </div>
            <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight font-display">
              Sürdürülebilir Büyüme İçin<br />Entegre Çözümler.
            </h2>
          </div>
          <a href="/tr/hizmetler/" class="text-gold font-semibold text-sm flex items-center gap-2 hover:gap-3 transition-all shrink-0">
            Tüm Hizmetler
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((service) => (
            <a href={service.href} class="card-light rounded-xl p-8 group">
              <div class="w-12 h-12 rounded-lg bg-navy flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-gold text-xl">{service.icon}</span>
              </div>
              <h3 class="text-lg font-bold text-heading mb-3 font-display group-hover:text-gold transition-colors">{service.title}</h3>
              <p class="text-body text-sm leading-relaxed mb-4">{service.desc}</p>
              <span class="text-gold text-sm font-semibold flex items-center gap-1 group-hover:gap-2 transition-all">
                Detaylı Bilgi
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ ABOUT / WHO WE HELP ═══ -->
    <section class="py-24 md:py-32 bg-slate">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Kiminle Çalışıyoruz</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight font-display mb-8">
              Büyümek İsteyen Şirketler İçin Stratejik Ortak.
            </h2>
            <div class="space-y-8">
              <div class="flex gap-5">
                <div class="stat-number text-2xl font-extrabold shrink-0 w-8">01</div>
                <div>
                  <h4 class="font-bold text-heading mb-1 font-display">Tedarikçiler</h4>
                  <p class="text-body text-sm leading-relaxed">Sertifikalı uyumluluk ile güvenilirliğinizi artırın ve birinci kademe partnerlerle bağlantı kurun.</p>
                </div>
              </div>
              <div class="flex gap-5">
                <div class="stat-number text-2xl font-extrabold shrink-0 w-8">02</div>
                <div>
                  <h4 class="font-bold text-heading mb-1 font-display">Orta Ölçekli Şirketler</h4>
                  <p class="text-body text-sm leading-relaxed">Daha güçlü sistemler, uyumluluk ve büyüme yapısı inşa edin.</p>
                </div>
              </div>
              <div class="flex gap-5">
                <div class="stat-number text-2xl font-extrabold shrink-0 w-8">03</div>
                <div>
                  <h4 class="font-bold text-heading mb-1 font-display">İş Sahipleri</h4>
                  <p class="text-body text-sm leading-relaxed">Yatırım, ölçeklendirme veya uzun vadeli stratejik konumlandırma için hazırlanın.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="relative">
            <img
              src="/images/meeting.jpg"
              alt="Curator ekip toplantısı"
              class="w-full aspect-[4/3] object-cover rounded-2xl"
              loading="lazy"
            />
            <div class="absolute -bottom-6 -left-6 bg-navy text-white p-6 rounded-xl max-w-[280px] hidden md:block">
              <p class="text-sm leading-relaxed mb-3 text-on-dark-secondary italic">"Curator uyumluluk yol haritamızı yeniden şekillendirerek bize aylarca zaman kazandırdı."</p>
              <div class="flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-gold"></div>
                <p class="text-xs font-bold tracking-wider uppercase text-on-dark-muted">CTO, Endüstriyel Şirket</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ METHODOLOGY ═══ -->
    <section class="py-24 md:py-32 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 relative z-10">
        <div class="text-center mb-16">
          <div class="flex items-center justify-center gap-3 mb-4">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Metodoloji</span>
            <div class="accent-line"></div>
          </div>
          <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight font-display">
            Nasıl Çalışıyoruz
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {steps.map((step, i) => (
            <div class={`card-dark rounded-xl p-8 relative ${i === 2 ? 'border-t-2 border-t-gold' : ''}`}>
              <span class="text-5xl font-extrabold text-navy-border font-display block mb-6">{step.num}</span>
              <h3 class="text-xl font-bold text-white mb-3 font-display">{step.title}</h3>
              <p class="text-on-dark-secondary text-sm leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="absolute top-1/2 left-[20%] w-64 h-64 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <!-- ═══ VISUAL BREAK ═══ -->
    <section class="bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6">
        <img
          src="/images/factory.jpg"
          alt="Endüstriyel üretim"
          class="w-full h-72 md:h-96 object-cover rounded-2xl"
          loading="lazy"
        />
      </div>
    </section>

    <!-- ═══ SECTORS ═══ -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
          <div>
            <div class="flex items-center gap-3 mb-4">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Sektörler</span>
            </div>
            <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight font-display mb-6">
              Hazırlığın Önemli Olduğu Sektörlerde Uzmanlaşıyoruz.
            </h2>
            <p class="text-body leading-relaxed mb-10">
              Büyüme, uyumluluk, tedarikçi yetkinliği ve güvenin sıkı sıkıya bağlı olduğu sektörlere odaklanıyoruz.
            </p>
            <a href="/tr/sektorler/" class="text-gold font-semibold text-sm flex items-center gap-2 hover:gap-3 transition-all">
              Tüm Sektörler
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { icon: 'shield', name: 'Savunma' },
              { icon: 'directions_car', name: 'Otomotiv' },
              { icon: 'precision_manufacturing', name: 'Endüstriyel Üretim' },
              { icon: 'memory', name: 'Teknoloji' },
            ].map((sector) => (
              <div class="card-light rounded-xl p-6 text-center">
                <div class="w-12 h-12 mx-auto rounded-lg bg-slate flex items-center justify-center mb-4">
                  <span class="material-symbols-outlined text-navy text-xl">{sector.icon}</span>
                </div>
                <p class="text-sm font-bold text-heading font-display">{sector.name}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CTA ═══ -->
    <section class="py-24 md:py-32 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <div class="flex items-center justify-center gap-3 mb-6">
          <div class="accent-line"></div>
        </div>
        <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight font-display mb-6">
          İşletmenizi Bir Sonraki Seviyeye Taşıyalım.
        </h2>
        <p class="text-on-dark-secondary text-lg mb-10 max-w-xl mx-auto">
          Büyüme ve hazırlık önceliklerinizi birlikte değerlendirelim.
        </p>
        <a href="/tr/iletisim/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Uzmanlarımızla Görüşün
        </a>
      </div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gold/5 rounded-full blur-[150px]"></div>
    </section>
  </main>
</BaseLayout>
