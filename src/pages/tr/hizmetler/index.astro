---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    icon: 'public',
    title: 'Stratejik Büyüme & Pazar Geliştirme',
    description: 'Yeni sektörlere girmek, yeni müşteri gruplarına ulaşmak veya daha odaklı bir büyüme stratejisi oluşturmak isteyen şirketlere destek.',
    href: '/tr/hizmetler/stratejik-buyume/',
    features: ['Pazar Analizi', 'Büyüme Stratejisi', 'Rekabet Haritalama'],
  },
  {
    icon: 'inventory',
    title: 'Tedarikçi Geliştirme & Denetim',
    description: 'Tedarikçilerin nerede durduğunu anlamasına, kritik açıkları kapatmasına ve daha sıkı müşteri beklentilerine hazırlanmasına destek.',
    href: '/tr/hizmetler/tedarikci-gelistirme/',
    features: ['Açık Analizi', 'Denetim Hazırlığı', 'Süreç İyileştirme'],
  },
  {
    icon: 'security',
    title: 'Uyumluluk & Bilgi Güvenliği',
    description: 'KVKK desteği, ISO 27001 hazırlığı ve uygulama desteği, dokümantasyon yapısı, iç denetim hazırlığı.',
    href: '/tr/hizmetler/uyumluluk-bilgi-guvenligi/',
    features: ['KVKK', 'ISO 27001', 'Dokümantasyon'],
  },
  {
    icon: 'cloud',
    title: 'IT, Ağ & Bulut Çözümleri',
    description: 'Ağ altyapısı, bulut geçişi, sistem modernizasyonu ve operasyonel IT ihtiyaç analizi.',
    href: '/tr/hizmetler/it-bulut-cozumleri/',
    features: ['Bulut Geçişi', 'Altyapı', 'Entegrasyon'],
  },
  {
    icon: 'account_balance',
    title: 'Finansal & Stratejik Danışmanlık',
    description: 'Şirket değerleme, stratejik planlama, büyüme senaryosu planlaması ve yatırıma hazırlık.',
    href: '/tr/hizmetler/finansal-danismanlik/',
    features: ['Değerleme', 'Yatırıma Hazırlık', 'Planlama'],
  },
];
---

<BaseLayout
  title="Hizmetler | CURATOR B2B Danışmanlık"
  description="Stratejik büyüme, tedarikçi geliştirme, uyumluluk, IT/bulut ve finansal danışmanlık hizmetlerimiz."
  locale="tr"
>
  <main>
    <!-- Hero -->
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="grid md:grid-cols-12 gap-8 items-end">
          <div class="md:col-span-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="accent-line"></div>
              <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Hizmet Portföyü</span>
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display">
              Sürdürülebilir Büyüme İçin Entegre Çözümler.
            </h1>
          </div>
          <div class="md:col-span-4 pb-2">
            <p class="text-on-dark-secondary leading-relaxed">
              Pazar stratejisinden denetim hazırlığına, IT yetkinliğinden stratejik finansa kadar şirketlerin bir sonraki büyüme aşaması için ihtiyaç duyduğu yetenekleri inşa ediyoruz.
            </p>
          </div>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <!-- Services Grid -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="space-y-6">
          {services.map((service, i) => (
            <a
              href={service.href}
              class="card-light rounded-2xl p-8 md:p-12 group block"
            >
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                <div class="lg:col-span-1">
                  <div class="w-14 h-14 rounded-xl bg-navy flex items-center justify-center">
                    <span class="material-symbols-outlined text-gold text-2xl">{service.icon}</span>
                  </div>
                </div>
                <div class="lg:col-span-7">
                  <div class="flex items-center gap-3 mb-3">
                    <span class="stat-number text-sm font-bold tracking-widest">{`0${i + 1}`}</span>
                    <div class="w-8 h-[1px] bg-gold/40"></div>
                  </div>
                  <h3 class="text-2xl md:text-3xl font-extrabold text-heading mb-4 font-display group-hover:text-gold transition-colors">
                    {service.title}
                  </h3>
                  <p class="text-body leading-relaxed">{service.description}</p>
                </div>
                <div class="lg:col-span-4 lg:border-l lg:border-border lg:pl-8">
                  <p class="text-xs uppercase tracking-widest text-muted font-bold mb-4">Kapsam</p>
                  <ul class="space-y-2">
                    {service.features.map((f) => (
                      <li class="flex items-center gap-2 text-sm text-body">
                        <span class="w-1 h-1 rounded-full bg-gold"></span>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <div class="mt-6 flex items-center gap-2 text-gold font-semibold text-sm group-hover:gap-3 transition-all">
                    Detaylı Bilgi
                    <span class="material-symbols-outlined text-sm">arrow_forward</span>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 md:py-32 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6 font-display">
          Doğru Başlangıç Noktasını Belirlemenize Yardımcı Olalım
        </h2>
        <p class="text-on-dark-secondary mb-10">Önceliklerinizi ilk toplantıda birlikte haritalandırabiliriz.</p>
        <a href="/tr/iletisim/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Toplantı Planla
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
