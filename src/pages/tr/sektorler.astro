---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sectors = [
  {
    icon: 'shield',
    title: 'Savunma',
    description: 'Tedarikçi hazırlığı, denetim hazırlığı, yapılandırılmış büyüme desteği ve talepkar ekosistemler için daha güçlü konumlandırma.',
  },
  {
    icon: 'directions_car',
    title: 'Otomotiv',
    description: 'Operasyonel disiplin, tedarikçi geliştirme, sistem hazırlığı ve pazar genişleme desteği.',
  },
  {
    icon: 'precision_manufacturing',
    title: 'Endüstriyel Üretim',
    description: 'Ticari büyüme planlaması, süreç olgunluğu, yönetişim ve teknoloji etkinleştirme.',
  },
  {
    icon: 'memory',
    title: 'Teknoloji & Dijital Hizmetler',
    description: 'Uyumluluk, bulut hazırlığı, bilgi güvenliği yapısı ve stratejik ölçeklendirme desteği.',
  },
];
---

<BaseLayout title="Sektörler | CURATOR" description="Hazırlığın önemli olduğu sektörler için inşa edildi." locale="tr">
  <main class="pt-20">
    <section class="px-6 md:px-8 py-24 md:py-32 bg-surface">
      <div class="max-w-4xl">
        <span class="text-xs font-bold tracking-[0.2em] text-on-primary-container uppercase block mb-4">Sektörler</span>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-primary-container mb-8 leading-[1.1] font-headline">
          Hazırlığın Önemli Olduğu Sektörler İçin İnşa Edildi.
        </h1>
        <p class="text-lg text-secondary leading-relaxed">
          Çalışmalarımız özellikle büyüme, uyumluluk, tedarikçi yetkinliği ve güvenin sıkı sıkıya bağlı olduğu sektörlerde geçerlidir.
        </p>
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
        {sectors.map((sector) => (
          <div class="bg-surface-container-lowest p-10 rounded-xl ghost-border hover:ambient-shadow transition-all">
            <div class="w-14 h-14 flex items-center justify-center bg-primary-container rounded-lg mb-6">
              <span class="material-symbols-outlined text-white text-2xl">{sector.icon}</span>
            </div>
            <h3 class="text-2xl font-bold text-primary-container mb-4 font-headline">{sector.title}</h3>
            <p class="text-secondary leading-relaxed">{sector.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-24 px-6 md:px-8 bg-surface">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-extrabold text-primary-container mb-6 font-headline">Sektörünüze Nasıl Destek Olabileceğimizi Görün</h2>
        <a href="/tr/iletisim/" class="inline-block signature-gradient text-white px-10 py-4 rounded-lg font-bold text-lg ambient-shadow hover:opacity-95 transition-all">
          Toplantı Planla
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
