---
import BaseLayout from '../../layouts/BaseLayout.astro';

const sectors = [
  {
    icon: 'shield',
    title: 'Savunma',
    description: 'Tedarikçi hazırlığı, denetim hazırlığı, yapılandırılmış büyüme desteği ve talepkar ekosistemler için daha güçlü konumlandırma.',
  },
  {
    icon: 'directions_car',
    title: 'Otomotiv',
    description: 'Operasyonel disiplin, tedarikçi geliştirme, sistem hazırlığı ve pazar genişleme desteği.',
  },
  {
    icon: 'precision_manufacturing',
    title: 'Endüstriyel Üretim',
    description: 'Ticari büyüme planlaması, süreç olgunluğu, yönetişim ve teknoloji etkinleştirme.',
  },
  {
    icon: 'memory',
    title: 'Teknoloji & Dijital Hizmetler',
    description: 'Uyumluluk, bulut hazırlığı, bilgi güvenliği yapısı ve stratejik ölçeklendirme desteği.',
  },
];
---

<BaseLayout title="Sektörler | CURATOR" description="Hazırlığın önemli olduğu sektörler için inşa edildi." locale="tr">
  <main>
    <!-- Hero -->
    <section class="bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 pt-32 pb-20 md:pt-40 md:pb-28 relative z-10">
        <div class="max-w-3xl">
          <div class="flex items-center gap-3 mb-6">
            <div class="accent-line"></div>
            <span class="text-gold text-xs font-semibold tracking-[0.2em] uppercase">Sektörler</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white leading-[1.1] tracking-tight font-display mb-6">
            Hazırlığın Önemli Olduğu Sektörler İçin İnşa Edildi.
          </h1>
          <p class="text-on-dark-secondary text-lg leading-relaxed">
            Büyüme, uyumluluk, tedarikçi yetkinliği ve güvenin sıkı sıkıya bağlı olduğu sektörlere odaklanıyoruz.
          </p>
        </div>
      </div>
      <div class="absolute top-20 right-[10%] w-72 h-72 bg-gold/5 rounded-full blur-[100px]"></div>
    </section>

    <!-- Sectors Grid -->
    <section class="py-24 md:py-32 bg-white">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {sectors.map((sector) => (
            <div class="card-light rounded-xl p-10">
              <div class="w-14 h-14 rounded-lg bg-navy flex items-center justify-center mb-6">
                <span class="material-symbols-outlined text-gold text-2xl">{sector.icon}</span>
              </div>
              <h3 class="text-2xl font-bold text-heading mb-4 font-display">{sector.title}</h3>
              <p class="text-body leading-relaxed">{sector.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Visual -->
    <section class="bg-slate">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-6">
        <img src="/images/factory.jpg" alt="Endüstriyel üretim" class="w-full h-72 md:h-96 object-cover rounded-2xl" loading="lazy" />
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 md:py-24 bg-hero relative overflow-hidden">
      <div class="hero-grid absolute inset-0"></div>
      <div class="max-w-3xl mx-auto px-6 lg:px-12 text-center relative z-10">
        <h2 class="text-3xl font-extrabold text-white mb-6 font-display">Sektörünüze Nasıl Destek Olabileceğimizi Görün</h2>
        <a href="/tr/iletisim/" class="btn-gold px-10 py-4 rounded-lg text-base inline-block">
          Toplantı Planla
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
